# ===== Backend HSJD — variables de entorno =====
# Copiá este archivo a `.env` y completá los secretos.
# Todos los valores no-secretos tienen defaults en src/config/configuration.ts.

# --- Flags de habilitación (red de seguridad en dev) ---
ACQUISITION_ENABLED=true
ALERTS_ENABLED=true

# --- Intervalos (ms) ---
INT_PLC_TRANSFER_POLL=2000
INT_TEMP_MODBUS_POLL=1000
INT_MONITOR_TICK=1000
INT_READINGS_PERSIST=300000
INT_WATER_POLL=60000
INT_SENSOR_RELOAD=60000
INT_MQTT_DISCONNECT_TICKS=10
ESC_RESEND_INTERVAL=1200000
ESC_ACK_EXTEND_INTERVAL=1800000

# --- Dispositivos Modbus TCP ---
PLC_RAMOS_HOST=192.168.90.231
PLC_RAMOS_PORT=502
PLC_TEMP_HOST=192.168.90.235
PLC_TEMP_PORT=502
PLC_CASTELAR_HOST=192.168.100.252
PLC_CASTELAR_PORT=8899
TANQUE_HOST=192.168.90.251
TANQUE_PORT=8899
CISTERNA_HOST=192.168.90.249
CISTERNA_PORT=8899

# --- MQTT ---
MQTT_URL=mqtt://localhost:8080
MQTT_TOPIC_FARMACIA=/sensor/temperatura/#
MQTT_TOPIC_SISTEMAS=/sistemas/temperatura/#

# --- Telegram ---
# Token del bot (Node-RED lo guardaba en credentials, NO en flows.json).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_RAMOS=-4086643597
TELEGRAM_CHAT_CASTELAR=-4949079047

# --- WhatsApp (Meta Graph API) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=602806129580480
WHATSAPP_DEFAULT_TO=1156166285

# --- Email SMTP (Office365) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CRM Ingenieria <crm.ingenieria@sanjuandedios.org.ar>

# --- Base de datos: sensores (PostgreSQL) ---
DB_SENSORS_HOST=192.168.90.219
DB_SENSORS_PORT=5432
DB_SENSORS_USER=postgres
DB_SENSORS_PASS=toor
DB_SENSORS_NAME=dbSensors

# --- Base de datos: PLC alarmas (SQL Server) ---
DB_PLC_HOST=192.168.90.200\SQLEXPRESS
DB_PLC_PORT=1433
DB_PLC_USER=guest
DB_PLC_PASS=1234
DB_PLC_NAME=E3_HSJD
DB_PLC_SCHEMA=dbo
